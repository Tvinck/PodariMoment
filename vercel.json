{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "node build.js",
  "outputDirectory": "dist",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    { "path": "/api/cron-check-orders", "schedule": "*/15 * * * *" }
  ],
  "rewrites": [
    { "source": "/order/:product", "destination": "/index.html" },
    { "source": "/order", "destination": "/index.html" },
    { "source": "/catalog", "destination": "/index.html" },
    { "source": "/account", "destination": "/index.html" },
    { "source": "/admin", "destination": "/index.html" },
    { "source": "/success", "destination": "/index.html" },
    { "source": "/track", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(woff2?|css|js|jsx|svg|webp|png|jpg|jpeg|mp3)$",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "interest-cohort=(), browsing-topics=()" }
      ]
    }
  ]
}
