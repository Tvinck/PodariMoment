# =========================================================
# ПодариМомент — environment variables template
# Copy to .env.local for local dev, set in Vercel Dashboard for prod.
# .env files are gitignored. Never commit real secrets.
# =========================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://podarimoment.ru
NEXT_PUBLIC_SUPPORT_EMAIL=hello@podarimoment.ru
NEXT_PUBLIC_TELEGRAM_HANDLE=@podarimoment

# --- AI / TTS (Voice generation — для гендер-пати голосов и ИИ-песен) ---
# Выберите одного провайдера или задайте оба для A/B:
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_MALE=
ELEVENLABS_VOICE_ID_FEMALE=
ELEVENLABS_VOICE_ID_CHILD=
ELEVENLABS_VOICE_ID_SHOWMAN=
YANDEX_SPEECHKIT_API_KEY=
YANDEX_SPEECHKIT_FOLDER_ID=
OPENAI_API_KEY=

# Kie.ai (ElevenLabs TTS) — генерация голоса для гендер-пати
KIE_API_KEY=

# --- Видео-генерация (Видео из фото, Оживить фото) ---
RUNWAY_API_KEY=
KLING_API_KEY=

# --- Платежи: Т-Банк (Tinkoff) эквайринг — основной ---
# Берутся из личного кабинета Т-Касса: https://www.tinkoff.ru/kassa/
TBANK_TERMINAL_KEY=
TBANK_PASSWORD=

# --- Supabase (заказы) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Прочие эквайринги (резерв, пока не используются) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
CLOUDPAYMENTS_PUBLIC_ID=
CLOUDPAYMENTS_API_SECRET=

# --- Email доставки готовых файлов ---
RESEND_API_KEY=
EMAIL_FROM=hello@podarimoment.ru

# --- Файловое хранилище для готовых mp3/mp4 ---
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=podarimoment-orders
S3_REGION=ru-central1
S3_ENDPOINT=https://storage.yandexcloud.net

# --- Аналитика ---
NEXT_PUBLIC_YANDEX_METRIKA_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Админ-доступ ---
# Пароль входа в админку. Проверяется ТОЛЬКО на сервере (/api/admin-orders),
# в браузер и window.__ENV__ не попадает.
ADMIN_PASSWORD=

# --- Telegram-уведомления о новых заказах ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
